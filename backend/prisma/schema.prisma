generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  PESTA_ADAT
  THREE_M
}

enum VendorType {
  VENUE
  CATERING
  ATTIRE
  GONDANG
  WO
  DOCUMENTATION
  CHURCH
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isAdmin  Boolean  @default(false) @map("is_admin")

  projects WeddingProject[]

  @@map("users")
}

model WeddingProject {
  id             String   @id @default(uuid())
  groomName      String   @map("groom_name")
  brideName      String   @map("bride_name")
  groomDomicile  String   @map("groom_domicile")
  brideDomicile  String   @map("bride_domicile")
  weddingDate    DateTime @map("wedding_date")
  totalBudget    Decimal  @map("total_budget") @db.Decimal(15, 2)
  guestCount     Int?     @map("guest_count")
  eventType      EventType @map("event_type")
  isFinalized    Boolean  @default(false) @map("is_finalized")
  finalizedAt    DateTime? @map("finalized_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userId     String @map("user_id")
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  events  Event[]
  vendors ProjectVendor[]

  @@map("wedding_projects")
}

model Event {
  id        String    @id @default(uuid())
  name      String
  type      EventType
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  projectId String         @map("project_id")
  project   WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  categories BudgetCategory[]

  @@map("events")
}

model BudgetCategory {
  id            String   @id @default(uuid())
  name          String
  plannedBudget Decimal  @default(0) @map("planned_budget") @db.Decimal(15, 2)
  actualCost    Decimal  @default(0) @map("actual_cost") @db.Decimal(15, 2)
  notes         String?
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("budget_categories")
}

model Vendor {
  id                String      @id @default(uuid())
  name              String
  type              VendorType
  location          String
  minPriceEstimate  Decimal     @map("min_price_estimate") @db.Decimal(15, 2)
  maxPriceEstimate  Decimal     @map("max_price_estimate") @db.Decimal(15, 2)
  capacity          Int?
  description       String?
  contactInfo       String?     @map("contact_info")
  isBatakSpecialist Boolean     @default(false) @map("is_batak_specialist")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  projectVendors ProjectVendor[]

  @@map("vendors")
}

model ProjectVendor {
  id            String   @id @default(uuid())
  notes         String?
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(15, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  projectId String         @map("project_id")
  project   WeddingProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  vendorId String @map("vendor_id")
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([projectId, vendorId])
  @@map("project_vendors")
}
